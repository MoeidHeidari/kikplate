                  "  pm.expect(body.error).to.equal(\"oauth provider not configured\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "OAuth - Callback missing code",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/github/callback?state=some-state",
              "host": ["{{base_url}}"],
              "path": ["auth", "github", "callback"],
              "query": [
                {
                  "key": "state",
                  "value": "some-state"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 400\", () => pm.response.to.have.status(400));",
                  "pm.test(\"Has error\", () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error).to.be.oneOf([\"missing oauth code\", \"invalid oauth state\"]);",
                  "});"
                ]
              }
            }
          ]
