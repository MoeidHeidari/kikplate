{
  "info": {
    "name": "Kickplate API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "verification_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"moeidheidari\",\n  \"email\": \"moe@example.com\",\n  \"password\": \"strongpassword123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Has message\", () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.include(\"verify your account\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register - duplicate email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"someone_else\",\n  \"email\": \"moe@example.com\",\n  \"password\": \"strongpassword123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 409\", () => pm.response.to.have.status(409));",
                  "pm.test(\"Has error\", () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error).to.equal(\"email already registered\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register - duplicate username",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
