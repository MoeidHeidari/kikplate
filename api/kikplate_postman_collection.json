                  "pm.test(\"Has error\", () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error).to.equal(\"token is required\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Email - invalid token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/verify-email?token=completely-wrong-token",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-email"],
              "query": [
                {
                  "key": "token",
                  "value": "completely-wrong-token"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 422\", () => pm.response.to.have.status(422));",
                  "pm.test(\"Has error\", () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error).to.equal(\"token invalid or expired\");",
                  "});"
                ]
              }
            }
          ]
        },
