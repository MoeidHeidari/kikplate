              }
            }
          ]
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/verify-email?token={{verification_token}}",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-email"],
              "query": [
                {
                  "key": "token",
                  "value": "{{verification_token}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Has token and account\", () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.a(\"string\");",
                  "  pm.expect(body.account).to.be.an(\"object\");",
                  "  pm.collectionVariables.set(\"token\", body.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Email - missing token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/verify-email",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-email"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
