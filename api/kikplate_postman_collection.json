        {
    "name": "Me",
    "request": {
        "method": "GET",
        "header": [
            {
                "key": "Authorization",
                "value": "Bearer {{token}}"
            }
        ],
        "url": {
            "raw": "{{base_url}}/me",
            "host": ["{{base_url}}"],
            "path": ["me"]
        }
    },
    "event": [
        {
            "listen": "test",
            "script": {
                "exec": [
                    "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                    "pm.test(\"Has account_id\", () => {",
                    "  const body = pm.response.json();",
                    "  pm.expect(body.account_id).to.be.a(\"string\");",
                    "  pm.expect(body.provider).to.be.a(\"string\");",
                    "});"
                ]
            }
        }
    ]
},
        {
          "name": "OAuth - GitHub Redirect",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/github/redirect",
              "host": ["{{base_url}}"],
              "path": ["auth", "github", "redirect"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.disableFollowRedirects = true;"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 307\", () => pm.response.to.have.status(307));",
                  "pm.test(\"Has Location header pointing to GitHub\", () => {",
                  "  const location = pm.response.headers.get(\"Location\");",
                  "  pm.expect(location).to.include(\"github.com/login/oauth/authorize\");",
                  "  pm.expect(location).to.include(\"state=\");",
                  "});",
                  "pm.test(\"Has oauth_state cookie\", () => {",
                  "  const cookie = pm.cookies.get(\"oauth_state\");",
                  "  pm.expect(cookie).to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "OAuth - GitHub Redirect (open in browser)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/github/redirect",
              "host": ["{{base_url}}"],
              "path": ["auth", "github", "redirect"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Redirected to GitHub\", () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 307]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.token) {",
                  "    pm.collectionVariables.set(\"token\", body.token);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "OAuth - GitHub Callback",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/github/callback?code={{github_code}}&state={{oauth_state}}",
              "host": ["{{base_url}}"],
              "path": ["auth", "github", "callback"],
              "query": [
                {
                  "key": "code",
                  "value": "{{github_code}}"
                },
                {
                  "key": "state",
                  "value": "{{oauth_state}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Has token and account\", () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.a(\"string\");",
                  "  pm.expect(body.account).to.be.an(\"object\");",
                  "  pm.expect(body.account.provider).to.equal(\"github\");",
                  "  pm.collectionVariables.set(\"token\", body.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "OAuth - Unknown Provider",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/unknown/redirect",
